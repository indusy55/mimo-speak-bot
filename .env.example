# Telegram admin user IDs, separated by commas or spaces.
ADMIN_IDS=

# Telegram bot token from BotFather.
TELEGRAM_BOT_TOKEN=

# Maximum Telegram audio upload size in bytes.
TELEGRAM_MEDIA_MAX_BYTES=5000000

# Optional ffmpeg executable path. Defaults to ffmpeg from PATH.
FFMPEG_PATH=

# API key for the TTS service.
TTS_API_KEY=

# Directory used to store local voice source files.
TTS_VOICE_SOURCES_DIR=./static
