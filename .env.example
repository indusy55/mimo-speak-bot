# Telegram bot token from BotFather.
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to manage voice sources.
ADMIN_IDS=

# Optional ffmpeg executable path. Defaults to ffmpeg from PATH.
FFMPEG_PATH=

# API key for the TTS service.
TTS_API_KEY=

# OpenAI-compatible API config (required for /sg natural language parsing).
# OPENAI_API_KEY=
# OPENAI_API_BASE_URL=https://api.openai.com/v1
# OPENAI_API_MODEL=gpt-4o-mini

# Maximum Telegram media file size to download, in bytes.
TELEGRAM_MEDIA_MAX_BYTES=5000000

# SQLite database file used to store voice source metadata.
DATABASE_URL=./data/voice-sources.db

# Directory used to store voice source audio files (content-addressed).
TTS_VOICE_SOURCES_DIR=./static
